# MeshView publishing secrets.
#
# Copy this file to `.env` and fill in your tokens. `.env` is gitignored, so real
# values never get committed. These are only needed to publish a release (see
# RELEASING.md); they are not required to build or run the extension.
#
#   cp .env.example .env
#
# Load them into your shell before publishing, e.g.:
#   Git Bash / macOS / Linux:  set -a; source .env; set +a
#   PowerShell:                Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }

# VS Code Marketplace Personal Access Token (scope: Marketplace > Manage).
# Used by `vsce`. See RELEASING.md for how to mint it.
# `npm run publish:vsce` reads this, or pass it explicitly: `npm run publish:vsce -- -p "$VSCE_PAT"`.
VSCE_PAT=

# Open VSX access token (from https://open-vsx.org account settings).
# Used by `ovsx`: `npm run publish:ovsx` reads OVSX_PAT.
OVSX_PAT=
